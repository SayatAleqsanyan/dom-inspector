{
    "manifest_version": 3,
    "name": "DOM Inspector",
    "version": "4.0.0",
    "description": "Inspect DOM elements, box model, selectors, flex/grid, accessibility, framework components \u2014 without opening DevTools.",
    "permissions": ["activeTab", "scripting", "storage"],
    "host_permissions": ["<all_urls>"],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        },
        "default_title": "DOM Inspector"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_idle",
            "all_frames": false
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "inspector.js",
                "inspector.css",
                "icons/icon16.png",
                "icons/icon48.png",
                "icons/icon128.png"
            ],
            "matches": ["<all_urls>"]
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
