{
    "name": "@armvs/dom-inspector",
    "version": "4.0.2",
    "description": "Lightweight DOM inspector inspired by browser DevTools. Inspect elements, visualize box model, view selectors and debug layouts directly on any webpage.",
    "main": "dist/inspector.min.js",
    "types": "dist/inspector.d.ts",
    "style": "dist/inspector.min.css",
    "scripts": {
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "build": "node scripts/build.js",
        "prepublishOnly": "npm run build",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui"
    },
    "keywords": [
        "dom",
        "inspector",
        "devtools",
        "debug",
        "layout",
        "css",
        "selector",
        "html",
        "developer-tools"
    ],
    "author": "Sayat",
    "license": "MIT",
    "type": "commonjs",
    "files": [
        "README.md",
        "dist/",
        "scripts/"
    ],
    "devDependencies": {
        "@playwright/test": "^1.44.0",
        "@vitest/coverage-v8": "^1.6.0",
        "jsdom": "^24.0.0",
        "terser": "^5.48.0",
        "vitest": "^1.6.0"
    },
    "exports": {
        ".": {
            "import": "./dist/inspector.esm.js",
            "require": "./dist/inspector.min.js",
            "default": "./dist/inspector.min.js"
        },
        "./css": "./dist/inspector.min.css",
        "./src": "./dist/inspector.js"
    },
    "module": "dist/inspector.esm.js",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/armvs/dom-inspector.git"
    },
    "homepage": "https://github.com/armvs/dom-inspector#readme",
    "bugs": {
        "url": "https://github.com/armvs/dom-inspector/issues"
    }
}
