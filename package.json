{
  "name": "@armvs/dom-inspector",
  "version": "2.3.0",
  "description": "Lightweight DOM inspector inspired by browser DevTools. Inspect elements, visualize box model, view selectors and debug layouts directly on any webpage.",
  "main": "dist/inspector.js",
  "types": "dist/inspector.d.ts",
  "style": "dist/inspector.css",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": ["dom","inspector","devtools","debug","layout","css","selector","html","developer-tools"],
  "author": "Sayat",
  "license": "MIT",
  "type": "commonjs",
  "files": ["README.md","dist/"],
  "devDependencies": {
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "jsdom": "^24.0.0",
    "@playwright/test": "^1.44.0"
  },
  "dependencies": {}
}
